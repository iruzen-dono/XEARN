# ============================================
# XEARN - Variables d'environnement PRODUCTION
# ⚠️ Ne JAMAIS committer ce fichier avec des vraies valeurs
# Utiliser les secrets manager des plateformes (Vercel, Railway)
# ============================================

# ─── ENVIRONNEMENT ───
NODE_ENV=production

# ─── DATABASE ───
# Neon PostgreSQL (format: postgresql://user:password@host:5432/dbname?sslmode=require)
DATABASE_URL="postgresql://[user]:[password]@[host].neon.tech:5432/xearn_prod?sslmode=require"

# ─── CORS ───
# Production: accepter uniquement le domaine
CORS_ORIGINS=https://xearn.com,https://www.xearn.com

# ─── JWT SECRETS ───
# ⚠️ Générer avec: openssl rand -hex 64
# ⚠️ CHANGER ces valeurs en production
JWT_SECRET="[générer-avec-openssl-rand-hex-64]"
JWT_REFRESH_SECRET="[générer-avec-openssl-rand-hex-64]"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# ─── API ───
API_PORT=4000
API_URL="https://api.xearn.com"

# ─── FRONTEND ───
NEXT_PUBLIC_API_URL="https://api.xearn.com"
NEXT_PUBLIC_APP_URL="https://xearn.com"
WEB_URL="https://xearn.com"

# ─── NEXTAUTH ───
NEXTAUTH_URL="https://xearn.com"
NEXTAUTH_SECRET="[générer-avec-openssl-rand-hex-32]"

# ─── GOOGLE OAUTH ───
# De: https://console.cloud.google.com/ → OAuth 2.0 Client ID (Web)
# Authorized redirect URIs:
#   - https://xearn.com/api/auth/callback/google
#   - https://staging.xearn.com/api/auth/callback/google
GOOGLE_CLIENT_ID="[your-client-id].apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="[your-client-secret]"

# ─── SMTP (Gmail avec App Password) ───
# 1. Créer un compte Gmail dédié pour les emails transactionnels
# 2. Activer 2FA
# 3. Générer App Password (Gmail → Account → Security → App passwords)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="[production-email@gmail.com]"
SMTP_PASS="[16-character-app-password]"
SMTP_FROM="XEARN <noreply@xearn.com>"

# ─── PAIEMENTS FEDAPAY ───
# Mode: production (pas mock)
PAYMENT_MODE="fedapay"
FEDAPAY_ENV="production"
FEDAPAY_SECRET_KEY="[FedaPay secret key — production]"
FEDAPAY_PUBLIC_KEY="[FedaPay public key — production]"
FEDAPAY_CALLBACK_URL="https://api.xearn.com/api/payment/webhook"
FEDAPAY_WEBHOOK_SECRET="[FedaPay webhook secret]"

# ─── ACTIVATIONS & RETRAITS ───
ACTIVATION_PRICE_FCFA=4000
WITHDRAWAL_MIN_FCFA=2000

# ─── PARRAINAGE ───
REFERRAL_LEVEL1_PERCENT=40
REFERRAL_LEVEL2_PERCENT=10
REFERRAL_LEVEL3_PERCENT=5

# ─── TIERS DE COMPTE ───
PREMIUM_PRICE_FCFA=10000
VIP_PRICE_FCFA=25000

# ─── MONITORING (Phase 2) ───
SENTRY_DSN="[Sentry project DSN]"
SENTRY_ENVIRONMENT="production"
SENTRY_TRACES_SAMPLE_RATE="0.1"

# ─── BACKUPS (Phase 2) ───
BACKUP_DIR="/var/backups/xearn"
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE="0 2 * * *"  # 2 AM daily

# ─── HEALTH CHECK ───
HEALTHCHECK_URL="https://api.xearn.com/api/health"
HEALTHCHECK_TIMEOUT_MS=5000
ALERT_WEBHOOK_URL="[optionnel: Slack/Discord webhook pour alertes]"

# ─── ADMIN SEED (À exécuter qu'une fois après migration) ───
# ⚠️ CHANGER LE MOT DE PASSE ADMIN
ADMIN_EMAIL="admin@xearn.com"
ADMIN_PASSWORD="[très-long-mot-de-passe-aléatoire]"
ADMIN_FIRST_NAME="Admin"
ADMIN_LAST_NAME="XEARN"

# ─── PRODUCTION OPS ───
# Environnement sécurisé
LOG_LEVEL="warn"
