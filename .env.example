# ============================================
# XEARN - Variables d'environnement
# ============================================

# Base de données PostgreSQL
DATABASE_URL="postgresql://xearn:xearn_password@localhost:5432/xearn_db?schema=public"

# JWT
JWT_SECRET="votre-secret-jwt-super-securise-changez-moi"
JWT_REFRESH_SECRET="votre-refresh-secret-jwt-changez-moi"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# API
API_PORT=4000
API_URL="http://localhost:4000"

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Paiements (Mock pour le moment)
PAYMENT_MODE="mock"

# Mobile Money (à configurer plus tard)
FLOOZ_API_KEY=""
TMONEY_API_KEY=""
MTN_MOMO_API_KEY=""
ORANGE_MONEY_API_KEY=""

# PayPal (à configurer plus tard)
PAYPAL_CLIENT_ID=""
PAYPAL_SECRET=""

# Activation
ACTIVATION_PRICE_FCFA=4000
WITHDRAWAL_MIN_FCFA=2000

# Parrainage
REFERRAL_LEVEL1_PERCENT=40
REFERRAL_LEVEL2_PERCENT=10
