# ============================================
# XEARN - Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================

# Environnement (development | production)
NODE_ENV=development

# CORS — origines autorisées (séparées par des virgules)
# En production : CORS_ORIGINS=https://xearn.com,https://www.xearn.com
CORS_ORIGINS=http://localhost:3000

# Base de données PostgreSQL
DATABASE_URL="postgresql://xearn:xearn_password@localhost:5432/xearn_db?schema=public"

# JWT — Générer avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="votre-secret-jwt-super-securise-changez-moi"
JWT_REFRESH_SECRET="votre-refresh-secret-jwt-changez-moi"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# API
API_PORT=4000
API_URL="http://localhost:4000"

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Web app URL (used for email verification links)
WEB_URL="http://localhost:3000"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="remplacez-par-un-secret-aleatoire"

# Google OAuth
GOOGLE_CLIENT_ID="votre-google-client-id"
GOOGLE_CLIENT_SECRET="votre-google-client-secret"

# Email SMTP (ex: Gmail avec mot de passe d'application)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER="votre.email@gmail.com"
SMTP_PASS="mot-de-passe-application"
SMTP_FROM="XEARN <votre.email@gmail.com>"

# Paiements (mock = dev, fedapay = production)
PAYMENT_MODE="mock"

# ── FedaPay (requis quand PAYMENT_MODE=fedapay) ──
FEDAPAY_SECRET_KEY=""
FEDAPAY_PUBLIC_KEY=""
FEDAPAY_ENV="sandbox"
FEDAPAY_CALLBACK_URL="http://localhost:4000/api/payment/webhook"
FEDAPAY_WEBHOOK_SECRET=""

# Activation & retrait
ACTIVATION_PRICE_FCFA=4000
WITHDRAWAL_MIN_FCFA=2000

# Parrainage (pourcentages de commission)
REFERRAL_LEVEL1_PERCENT=40
REFERRAL_LEVEL2_PERCENT=10
REFERRAL_LEVEL3_PERCENT=5

# Niveaux de compte (prix d'upgrade en FCFA)
PREMIUM_PRICE_FCFA=10000
VIP_PRICE_FCFA=25000

# ── Admin seed (prisma db seed) ──
ADMIN_EMAIL="admin@xearn.local"
ADMIN_PASSWORD="Admin1234"
ADMIN_FIRST_NAME="Admin"
ADMIN_LAST_NAME="XEARN"
