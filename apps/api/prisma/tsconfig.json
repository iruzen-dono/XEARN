{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "outDir": "./dist",
    "paths": {
      ".prisma/client/default": ["../../node_modules/.prisma/client/index.d.ts"],
      ".prisma/*": ["../../node_modules/.prisma/*"]
    }
  },
  "include": ["./**/*.ts"]
}
