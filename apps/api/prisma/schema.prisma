// This is your Prisma schema file for XEARN
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// UTILISATEURS
// ==========================================

enum UserRole {
  USER
  PARTNER   // Pub Maker — peut créer des campagnes publicitaires
  ADMIN
}

enum AccountStatus {
  FREE        // Compte gratuit - pas de retrait
  ACTIVATED   // Compte activé (4000 FCFA payé)
  SUSPENDED
  BANNED
}

enum AccountTier {
  NORMAL      // Tâches standard, parrainage L1 uniquement
  PREMIUM     // + tâches premium, parrainage L1+L2, frais retrait réduits
  VIP         // + tâches VIP, parrainage L1+L2+L3 (5%), frais min
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

model User {
  id            String        @id @default(cuid())
  email         String?       @unique
  phone         String?       @unique
  password      String?
  firstName     String
  lastName      String
  role          UserRole      @default(USER)
  status        AccountStatus @default(FREE)
  tier          AccountTier   @default(NORMAL)
  referralCode  String        @unique @default(cuid())
  avatarUrl     String?
  provider      AuthProvider  @default(LOCAL)
  googleId      String?       @unique
  emailVerifiedAt DateTime?
  emailVerificationToken String?
  emailVerificationExpiresAt DateTime?

  // Parrainage
  referredById  String?
  referredBy    User?         @relation("Referrals", fields: [referredById], references: [id])
  referrals     User[]        @relation("Referrals")

  // Relations
  wallet        Wallet?
  taskCompletions TaskCompletion[]
  transactions  Transaction[]
  withdrawals   Withdrawal[]
  commissionsReceived  Commission[] @relation("CommissionsReceived")
  commissionsGenerated Commission[] @relation("CommissionsGenerated")
  notifications        Notification[]
  streak               UserStreak?
  userBadges           UserBadge[]
  advertisements       Advertisement[]

  // OTP
  otpCode       String?
  otpExpiresAt  DateTime?

  // Password reset
  passwordResetToken     String?
  passwordResetExpiresAt DateTime?

  // Token versioning — incremented on password change to invalidate all sessions
  tokenVersion  Int       @default(0)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([referredById])
  @@index([status])
  @@map("users")
}

// ==========================================
// PORTEFEUILLE
// ==========================================

model Wallet {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance     Decimal  @default(0) @db.Decimal(12, 2)
  totalEarned Decimal  @default(0) @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("wallets")
}

// ==========================================
// TÂCHES (PUBLICITÉS)
// ==========================================

enum TaskType {
  VIDEO_AD      // Visionnage de pub vidéo
  CLICK_AD      // Clic sur publicité
  SURVEY        // Sondage sponsorisé
  SPONSORED     // Tâche sponsorisée
}

enum TaskStatus {
  ACTIVE
  PAUSED
  COMPLETED
  EXPIRED
}

model Task {
  id              String      @id @default(cuid())
  title           String
  description     String?
  type            TaskType
  status          TaskStatus  @default(ACTIVE)
  reward          Decimal     @db.Decimal(10, 2)  // Rémunération en FCFA
  mediaUrl        String?     // URL de la vidéo/image
  externalUrl     String?     // Lien externe
  requiredTier    AccountTier @default(NORMAL) // Tier minimum requis
  maxCompletions  Int?        // Nombre max de complétions
  completionCount Int         @default(0)
  expiresAt       DateTime?

  completions     TaskCompletion[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([status, requiredTier])
  @@index([status, expiresAt])
  @@map("tasks")
}

model TaskCompletion {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  earned    Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  @@unique([userId, taskId])
  @@index([userId])
  @@index([taskId])
  @@map("task_completions")
}

// Session de tâche : track le début pour validation anti-triche
model TaskSession {
  id        String   @id @default(cuid())
  userId    String
  taskId    String
  startedAt DateTime @default(now())
  completed Boolean  @default(false)

  @@unique([userId, taskId])
  @@map("task_sessions")
}

// ==========================================
// TRANSACTIONS & PAIEMENTS
// ==========================================

enum TransactionType {
  ACTIVATION      // Paiement d'activation (4000 FCFA)
  TASK_EARNING    // Gain tâche
  REFERRAL_L1     // Commission parrainage niveau 1
  REFERRAL_L2     // Commission parrainage niveau 2
  REFERRAL_L3     // Commission parrainage niveau 3 (VIP)
  WITHDRAWAL      // Retrait
  TIER_UPGRADE    // Upgrade de tier (Premium/VIP)
  PUB_MAKER       // Abonnement Pub Maker
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model Transaction {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        TransactionType
  status      TransactionStatus @default(PENDING)
  amount      Decimal           @db.Decimal(12, 2)
  description String?
  metadata    Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([userId])
  @@index([userId, type, status])
  @@map("transactions")
}

// ==========================================
// RETRAITS
// ==========================================

enum PaymentMethod {
  FLOOZ
  TMONEY
  MTN_MOMO
  ORANGE_MONEY
  VISA
  MASTERCARD
  PAYPAL
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

model Withdrawal {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount        Decimal          @db.Decimal(12, 2)
  method        PaymentMethod
  status        WithdrawalStatus @default(PENDING)
  accountInfo   String           // Numéro de téléphone, email PayPal, etc.
  processedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([userId])
  @@index([status])
  @@map("withdrawals")
}

// ==========================================
// COMMISSIONS DE PARRAINAGE
// ==========================================

model Commission {
  id            String   @id @default(cuid())
  beneficiaryId String
  beneficiary   User     @relation("CommissionsReceived", fields: [beneficiaryId], references: [id], onDelete: Cascade)
  sourceUserId  String
  sourceUser    User     @relation("CommissionsGenerated", fields: [sourceUserId], references: [id], onDelete: Cascade)
  level         Int      // 1 ou 2
  percentage    Decimal  @db.Decimal(5, 2)
  amount        Decimal  @db.Decimal(12, 2)
  createdAt     DateTime @default(now())

  @@index([beneficiaryId])
  @@index([sourceUserId])
  @@map("commissions")
}

// ==========================================
// ANTI-TRICHE : EMPREINTES DIGITALES
// ==========================================

model DeviceFingerprint {
  id            String   @id @default(cuid())
  userId        String
  fingerprint   String   // Hash du navigateur (canvas, UA, screen, etc.)
  ipAddress     String?
  userAgent     String?
  lastSeenAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  @@unique([userId, fingerprint])
  @@index([fingerprint])
  @@index([ipAddress])
  @@map("device_fingerprints")
}

// ==========================================
// NOTIFICATIONS
// ==========================================

enum NotificationType {
  WELCOME
  TASK_COMPLETED
  COMMISSION_RECEIVED
  WITHDRAWAL_APPROVED
  WITHDRAWAL_REJECTED
  ACCOUNT_ACTIVATED
  NEW_REFERRAL
  SYSTEM
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@map("notifications")
}

// ==========================================
// GAMIFICATION : STREAKS & BADGES
// ==========================================

model UserStreak {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStreak   Int      @default(0)
  longestStreak   Int      @default(0)
  lastActivityDate DateTime? // Date (sans heure) de la dernière activité
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("user_streaks")
}

model Badge {
  id          String   @id @default(cuid())
  code        String   @unique  // ex: "streak_7", "tasks_50", "referrals_10"
  name        String             // ex: "Flamme 7 jours"
  description String
  icon        String             // emoji or icon name
  category    BadgeCategory
  threshold   Int                // valeur seuil pour obtenir le badge
  reward      Decimal? @db.Decimal(10, 2) // bonus FCFA optionnel
  createdAt   DateTime @default(now())

  userBadges  UserBadge[]

  @@map("badges")
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt  DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}

enum BadgeCategory {
  STREAK      // Jours consécutifs
  TASKS       // Nombre total de tâches
  REFERRALS   // Nombre de filleuls
  EARNINGS    // Total gagné
}

// ==========================================
// PUBLICITÉS (PUB MAKER)
// ==========================================

enum AdStatus {
  PENDING
  ACTIVE
  PAUSED
  EXPIRED
  REJECTED
}

model Advertisement {
  id              String   @id @default(cuid())
  publisherId     String
  publisher       User     @relation(fields: [publisherId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  mediaUrl        String?
  targetUrl       String?
  status          AdStatus @default(PENDING)
  targetCountries String[] @default([])  // ex: ["TG","BJ","CI"] — vide = tous
  targetTiers     AccountTier[] @default([]) // ex: [PREMIUM, VIP] — vide = tous
  budget          Decimal? @db.Decimal(12, 2) // Budget total de la campagne
  spent           Decimal  @default(0) @db.Decimal(12, 2)
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, publisherId])
  @@index([status, expiresAt])
  @@map("advertisements")
}

// ==========================================
// AUDIT LOGS (ADMIN)
// ==========================================

model AuditLog {
  id          String   @id @default(cuid())
  adminId     String
  action      String   // ex: "SUSPEND_USER", "BAN_USER", "APPROVE_WITHDRAWAL", etc.
  targetType  String   // ex: "User", "Withdrawal", "Advertisement"
  targetId    String
  details     Json?    // Détails supplémentaires
  createdAt   DateTime @default(now())

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}
