// This is your Prisma schema file for XEARN
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// UTILISATEURS
// ==========================================

enum UserRole {
  USER
  ADMIN
}

enum AccountStatus {
  FREE        // Compte gratuit - pas de retrait
  ACTIVATED   // Compte activé (4000 FCFA payé)
  SUSPENDED
  BANNED
}

model User {
  id            String        @id @default(cuid())
  email         String?       @unique
  phone         String?       @unique
  password      String
  firstName     String
  lastName      String
  role          UserRole      @default(USER)
  status        AccountStatus @default(FREE)
  referralCode  String        @unique @default(cuid())
  avatarUrl     String?

  // Parrainage
  referredById  String?
  referredBy    User?         @relation("Referrals", fields: [referredById], references: [id])
  referrals     User[]        @relation("Referrals")

  // Relations
  wallet        Wallet?
  taskCompletions TaskCompletion[]
  transactions  Transaction[]
  withdrawals   Withdrawal[]
  commissionsReceived  Commission[] @relation("CommissionsReceived")
  commissionsGenerated Commission[] @relation("CommissionsGenerated")

  // OTP
  otpCode       String?
  otpExpiresAt  DateTime?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("users")
}

// ==========================================
// PORTEFEUILLE
// ==========================================

model Wallet {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance     Decimal  @default(0) @db.Decimal(12, 2)
  totalEarned Decimal  @default(0) @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("wallets")
}

// ==========================================
// TÂCHES (PUBLICITÉS)
// ==========================================

enum TaskType {
  VIDEO_AD      // Visionnage de pub vidéo
  CLICK_AD      // Clic sur publicité
  SURVEY        // Sondage sponsorisé
  SPONSORED     // Tâche sponsorisée
}

enum TaskStatus {
  ACTIVE
  PAUSED
  COMPLETED
  EXPIRED
}

model Task {
  id              String      @id @default(cuid())
  title           String
  description     String?
  type            TaskType
  status          TaskStatus  @default(ACTIVE)
  reward          Decimal     @db.Decimal(10, 2)  // Rémunération en FCFA
  mediaUrl        String?     // URL de la vidéo/image
  externalUrl     String?     // Lien externe
  maxCompletions  Int?        // Nombre max de complétions
  completionCount Int         @default(0)
  expiresAt       DateTime?

  completions     TaskCompletion[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("tasks")
}

model TaskCompletion {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  earned    Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  @@unique([userId, taskId])
  @@map("task_completions")
}

// ==========================================
// TRANSACTIONS & PAIEMENTS
// ==========================================

enum TransactionType {
  ACTIVATION      // Paiement d'activation (4000 FCFA)
  TASK_EARNING    // Gain tâche
  REFERRAL_L1     // Commission parrainage niveau 1
  REFERRAL_L2     // Commission parrainage niveau 2
  WITHDRAWAL      // Retrait
  PUB_MAKER       // Abonnement Pub Maker
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model Transaction {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        TransactionType
  status      TransactionStatus @default(PENDING)
  amount      Decimal           @db.Decimal(12, 2)
  description String?
  metadata    Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("transactions")
}

// ==========================================
// RETRAITS
// ==========================================

enum PaymentMethod {
  FLOOZ
  TMONEY
  MTN_MOMO
  ORANGE_MONEY
  VISA
  MASTERCARD
  PAYPAL
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

model Withdrawal {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount        Decimal          @db.Decimal(12, 2)
  method        PaymentMethod
  status        WithdrawalStatus @default(PENDING)
  accountInfo   String           // Numéro de téléphone, email PayPal, etc.
  processedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@map("withdrawals")
}

// ==========================================
// COMMISSIONS DE PARRAINAGE
// ==========================================

model Commission {
  id            String   @id @default(cuid())
  beneficiaryId String
  beneficiary   User     @relation("CommissionsReceived", fields: [beneficiaryId], references: [id], onDelete: Cascade)
  sourceUserId  String
  sourceUser    User     @relation("CommissionsGenerated", fields: [sourceUserId], references: [id], onDelete: Cascade)
  level         Int      // 1 ou 2
  percentage    Decimal  @db.Decimal(5, 2)
  amount        Decimal  @db.Decimal(12, 2)
  createdAt     DateTime @default(now())

  @@map("commissions")
}

// ==========================================
// PUBLICITÉS (PUB MAKER)
// ==========================================

enum AdStatus {
  PENDING
  ACTIVE
  PAUSED
  EXPIRED
  REJECTED
}

model Advertisement {
  id          String   @id @default(cuid())
  publisherId String   // ID de l'utilisateur/entreprise
  title       String
  description String?
  mediaUrl    String?
  targetUrl   String?
  status      AdStatus @default(PENDING)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("advertisements")
}
