{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "description": "XEARN API - NestJS Backend",
  "scripts": {
    "clean": "node -e \"const fs=require('fs'); for (const target of ['dist','tsconfig.tsbuildinfo']) { fs.rmSync(target, { recursive: true, force: true }); }\"",
    "prebuild": "npm run clean",
    "build": "npx nest build",
    "start": "npx nest start",
    "start:dev": "npm run build && node dist/main",
    "start:dev:watch": "npx nest start --watch",
    "start:prod": "node dist/main",
    "test": "jest",
    "db:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "db:migrate:prod": "npx prisma migrate deploy",
    "db:push": "npx prisma db push --accept-data-loss",
    "db:seed": "npx ts-node prisma/seed.ts",
    "db:seed-test": "npx ts-node prisma/seed-test-data.ts",
    "db:seed-prod": "npx ts-node prisma/seed-prod.ts",
    "db:studio": "npx prisma studio"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.9.0",
    "@sentry/node": "^10.53.1",
    "@xearn/types": "file:../../packages/types",
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "google-auth-library": "^10.6.1",
    "helmet": "^8.1.0",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.0",
    "@types/nodemailer": "^6.4.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "jest": "^29.7.0",
    "prisma": "^6.9.0",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "typescript": "5.8.3"
  }
}
