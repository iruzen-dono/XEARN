{
  "name": "xearn",
  "version": "1.0.0",
  "private": true,
  "description": "XEARN - Plateforme panafricaine de micro-revenus digitaux",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run start:dev --workspace=apps/api",
    "build": "npm run build --workspaces",
    "build:web": "npm run build --workspace=apps/web",
    "build:api": "npm run build --workspace=apps/api",
    "lint": "npm run lint --workspace=apps/web",
    "lint:fix": "npm run lint --workspace=apps/web -- --fix",
    "format": "prettier --write \"apps/**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,json,css,md}\"",
    "test": "npm run test --workspace=apps/api",
    "check": "npm run lint --workspace=apps/web && npm run test --workspace=apps/api",
    "prepare": "husky",
    "db:migrate": "npm run db:migrate --workspace=apps/api",
    "db:generate": "npm run db:generate --workspace=apps/api",
    "db:seed": "npm run db:seed --workspace=apps/api",
    "db:studio": "npm run db:studio --workspace=apps/api"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.1",
    "typescript": "5.8.3"
  },
  "overrides": {
    "typescript": "5.8.3"
  },
  "dependencies": {
    "@nestjs/event-emitter": "^3.0.1"
  },
  "lint-staged": {
    "apps/**/*.{ts,tsx}": [
      "prettier --write"
    ],
    "apps/**/*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
